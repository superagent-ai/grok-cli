{
  "name": "grok-dev",
  "version": "1.0.0",
  "description": "An open-source AI coding agent powered by Grok, built with Bun and OpenTUI.",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "grok": "dist/index.js"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "tsc",
    "start": "bun run dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "format": "biome format src/",
    "format:fix": "biome format --write src/",
    "lint:fix": "biome check --fix src/",
    "pre-commit": "lint-staged",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json}": "biome check --write --no-errors-on-unmatched"
  },
  "keywords": [
    "cli",
    "agent",
    "grok",
    "ai",
    "coding",
    "terminal",
    "opentui"
  ],
  "author": "Vibe Kit",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/xai": "^3.0.67",
    "@opentui/core": "^0.1.88",
    "@opentui/react": "^0.1.88",
    "ai": "^6.0.116",
    "commander": "^12.1.0",
    "diff": "^8.0.3",
    "dotenv": "^16.6.1",
    "react": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/diff": "^8.0.0",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "preferGlobal": true
}
